{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev Server",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["node_modules/.bin/next", "dev", "--webpack", "--port", "3002"],
      "env": { "NEXT_PUBLIC_PREVIEW_MODE": "true" },
      "cwd": "ag_crm",
      "port": 3002
    },
    {
      "name": "Convex Backend",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["convex", "dev"],
      "cwd": "ag_crm",
      "port": 3001,
      "autoPort": true
    }
  ]
}
